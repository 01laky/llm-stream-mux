flowchart TB
	subgraph SOURCES["Concurrent sources"]
		S1["gpt"]
		S2["claude"]
		S3["backup"]
	end

	subgraph MUX["merge() / ensemble read-loop"]
		READY["ready Map · settled reads retained"]
		PENDING["One in-flight read per active source"]
		BP["backpressure · max 1 Tagged queued"]
		ORD["order: arrival | round-robin cursor"]
		CONC["concurrency cap · FIFO waiting queue"]
		READY --> BP --> ORD
		PENDING --> READY
		CONC --> PENDING
	end

	subgraph OUT["Tagged output stream"]
		V["kind: value · source + U"]
		E["kind: error · MuxError"]
		D["kind: done · source ended"]
	end

	S1 --> PENDING
	S2 --> PENDING
	S3 --> CONC
	ORD --> V
	ORD --> E
	ORD --> D

	OBS["onSourceEvent · out-of-band telemetry"]
	MUX --> OBS

