flowchart TD
	START(["What do you need?"])

	START --> COUNT{How many live streams?}
	COUNT -->|One stream, many consumers| TEE["tee(source, n)<br/>bounded backpressure"]
	COUNT -->|Many streams, one output| GOAL{Goal?}

	GOAL -->|Fastest response wins| RACE["race(sources)<br/>cancel losers"]
	GOAL -->|Primary → backup on failure| FB["fallback(sources)<br/>lazy thunks recommended"]
	GOAL -->|Run models in parallel| MRG["merge(sources)<br/>Tagged&lt;T&gt; per source"]

	RACE --> HOOKS{Need semantic gates?}
	FB --> HOOKS
	MRG --> HOOKS
	HOOKS -->|yes| OPT["isUsable · isError · isFinal · mapEach"]
	HOOKS -->|no| DONE(["AsyncIterable or ReadableStream[]"])

	OPT --> DONE
	TEE --> DONE

	BYTE{Raw bytes or parsed events?}
	BYTE -->|Uint8Array before assemble| BM["Byte mode · T = Uint8Array"]
	BYTE -->|After assemble / guard| EM["Event mode · T = your event type"]
	BM --> COUNT
	EM --> COUNT

	ASM["Need provider parsing?"]
	ASM --> AOUT["Use llm-stream-assemble first · see ecosystem diagram"]
	PARSE["Need security filter?"]
	PARSE --> POUT["Use llm-stream-guard · docs/integration-cookbook.md"]

