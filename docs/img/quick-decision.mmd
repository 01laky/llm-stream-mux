	classDef out fill:#134e4a,stroke:#2dd4bf,stroke-width:2px,color:#f0fdfa
	classDef note fill:#451a03,stroke:#fb923c,stroke-width:1px,color:#ffedd5

	class RACE,FB,MRG,TEE,OPT,BYTE,BM,EM pick
	class DONE out
