flowchart TB
	subgraph RACE["race · first usable wins"]
		R1["Start N sources"]
		R2["First usable item commits"]
		R3["Cancel losers · race-lost"]
		R1 --> R2 --> R3
	end

	subgraph FB["fallback · priority failover"]
		F1["Try source 1"]
		F2{"Failed pre-commit?"}
		F3["Lazy thunk → source 2"]
		F4["FailoverPolicy · commit / buffered / post-emit"]
		F1 --> F2
		F2 -->|yes| F3
		F2 -->|no| F4
	end

	subgraph MERGE["merge · concurrent ensemble"]
		M1["All sources active"]
		M2["Tagged value / error / done"]
		M3["One failure ≠ kill others"]
		M1 --> M2 --> M3
	end

	subgraph TEE["tee · 1→N fan-out"]
		T1["One source"]
		T2["N independent branches"]
		T3["block · bounded · drop backpressure"]
		T1 --> T2 --> T3
	end

	classDef strat fill:#042f2e,stroke:#2dd4bf,stroke-width:2px,color:#ccfbf1
	class R1,R2,R3,F1,F2,F3,F4,M1,M2,M3,T1,T2,T3 strat
