{
	"name": "llm-stream-mux",
	"version": "1.1.0",
	"description": "Zero-dependency TypeScript stream orchestration for LLM pipelines — race, fallback, merge, and tee over any AsyncIterable or ReadableStream, generic over T.",
	"license": "MIT",
	"author": "Ladislav Kostolny <01laky@gmail.com>",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
		"typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"smoke:package": "node scripts/smoke-package.mjs",
		"smoke:runtimes": "node scripts/smoke-runtimes.mjs",
		"smoke:consumer": "node scripts/smoke-consumer.mjs",
		"smoke:published": "node scripts/smoke-published.mjs",
		"diagrams:build": "node scripts/build-diagrams.mjs",
		"diagrams:check": "node scripts/check-diagrams.mjs",
		"verify:deps": "node scripts/verify-zero-deps.mjs",
		"verify:portability": "node scripts/check-portability.mjs",
		"verify:docs": "node scripts/verify-docs.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"verify": "pnpm verify:deps && pnpm verify:portability && pnpm lint && pnpm typecheck && pnpm build && pnpm typecheck:examples && pnpm test && pnpm smoke:package && pnpm verify:docs && pnpm diagrams:check && pnpm format",
		"verify:pre1": "pnpm verify && pnpm release:prep && pnpm smoke:runtimes --skip-optional && pnpm smoke:consumer && pnpm smoke:published",
		"release:prep": "node scripts/release-prep.mjs"
	},
	"keywords": [
		"llm",
		"llm-stream",
		"streaming",
		"stream-mux",
		"stream-orchestration",
		"race",
		"fallback",
		"failover",
		"merge",
		"ensemble",
		"tee",
		"fan-out",
		"readablestream",
		"async-iterable",
		"typescript",
		"composable",
		"web-streams",
		"zero-dependencies"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/01laky/llm-stream-mux.git"
	},
	"bugs": {
		"url": "https://github.com/01laky/llm-stream-mux/issues"
	},
	"homepage": "https://github.com/01laky/llm-stream-mux#readme",
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@11.5.2",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.13.1",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.4.1",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.8"
	}
}
